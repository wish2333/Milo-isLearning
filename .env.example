# ===== AI Learning Compiler 环境变量示例 =====
# 复制为 .env.local 填入真实值；真实 key 绝不要 commit。
# bun 默认不自动加载 .env.local，运行脚本时需显式：
#   bun --env-file=.env.local run scripts/ping.ts
#   bun --env-file=.env.local run scripts/prompt-eval.ts

# 应用版本
NEXT_PUBLIC_APP_VERSION=1.0.0

# ===== v1.0.0 应用模式（默认 showcase）=====
# 不设或设为 showcase：展示页（Vercel 部署、本地 showcase 预览）
# 设为 production：启用本地 SQLite 持久化（需配合 ALC_STORAGE_BACKEND）
# NEXT_PUBLIC_APP_MODE=showcase

# ===== v1.0.0 SQLite 后端开关（server-only，仅 production 模式生效）=====
# 不设：production 模式下 /api/data/* 全部返回 404（fail-closed）
# 设为 sqlite：启用本地 SQLite（data/alc.db），与 NEXT_PUBLIC_APP_MODE=production 同时生效
# ALC_STORAGE_BACKEND=sqlite

# ===== 默认 LLM 供应商 / 模型（用户可在 Settings 中覆盖）=====
# 取值：deepseek | glm | openai-compat（v1.0.0 起 sensenova 已移除）
DEFAULT_LLM_PROVIDER=deepseek

# 默认模型（必须随 DEFAULT_LLM_PROVIDER 走对应供应商）：
#   deepseek     ：deepseek-v4-flash（推荐）/ deepseek-v4-pro（强）
#   glm          ：glm-5.2（旗舰）/ glm-5-turbo（快速）
#                  旧 ID（已过时）：glm-4-plus / glm-4-flash / glm-4.7
#   openai-compat：自定义（如 gpt-4o-mini），需配合 OPENAI_COMPAT_BASE_URL
DEFAULT_LLM_MODEL=deepseek-v4-flash

# 遥测后端（MVP 用 console）
# 取值：console | none
TELEMETRY_BACKEND=console

# ===== 供应商 API Key（按需配置至少一项）=====

# 原生 DeepSeek：https://api.deepseek.com
DEEPSEEK_API_KEY=

# 智谱 GLM：https://bigmodel.cn
# 同一 API Key 可走 Coding Plan 端点或公开端点（看下方 BASE_URL 配置）
GLM_API_KEY=

# 通用 OpenAI 兼容供应商（BYO baseURL + apiKey）
# 适配任何兼容 OpenAI Chat Completions 协议的服务（如 OpenRouter、Together、自部署 vLLM 等）
OPENAI_COMPAT_API_KEY=

# ===== 可选：覆盖各供应商默认模型 =====
# DEEPSEEK_MODEL=deepseek-v4-flash
# GLM_MODEL=glm-5.2
# OPENAI_COMPAT_MODEL=gpt-4o-mini

# ===== 可选：覆盖各供应商默认 baseURL =====

# 原生 DeepSeek 默认：https://api.deepseek.com（不带 /v1，由 provider 自动加）
# DEEPSEEK_BASE_URL=

# GLM 默认走 Coding Plan 端点（/api/coding/paas/v4）；
# 切换回公开端点：https://open.bigmodel.cn/api/paas/v4
# GLM_BASE_URL=

# OpenAI 兼容供应商必须显式设 baseURL（无默认值）
# 例如 OpenRouter：https://openrouter.ai/api/v1
# 例如 Together：https://api.together.xyz/v1
# OPENAI_COMPAT_BASE_URL=

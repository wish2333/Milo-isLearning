# ===== AI Learning Compiler 环境变量示例 =====
# 复制为 .env.local 并填入真实值；真实 key 永远不要 commit

# 应用版本
NEXT_PUBLIC_APP_VERSION=0.1.0-m1

# 默认 LLM 供应商（用户可在 Settings 中覆盖）
# 取值：deepseek | glm
DEFAULT_LLM_PROVIDER=deepseek

# 默认模型名（与 DEFAULT_LLM_PROVIDER 配套）
# DeepSeek 推荐：deepseek-v4-flash（快速）/ deepseek-v4-pro（强）
#   旧 ID（deepseek-chat / deepseek-reasoner）2026-07-24 退役
# GLM 推荐（Coding Plan 端点）：glm-5.2（强）/ glm-5-turbo（快速）
#   旧 ID（glm-4-plus / glm-4-flash / glm-4.7）已过时
DEFAULT_LLM_MODEL=deepseek-v4-flash

# 埋点后端（MVP 用 console）
# 取值：console | none
TELEMETRY_BACKEND=console

# ===== 仅用于 ping 测试（scripts/ping.ts）=====
# 不设则 ping 脚本会自动 skip 该供应商
# DEEPSEEK_API_KEY=
# GLM_API_KEY=

# 可选：覆盖默认模型名
# DEEPSEEK_MODEL=deepseek-v4-flash
# GLM_MODEL=glm-5.2

# 可选：覆盖默认 baseURL
# GLM 默认走 Coding Plan 端点（/api/coding/paas/v4）。
# 如需切回公开端点，改为 https://open.bigmodel.cn/api/paas/v4
# GLM_BASE_URL=

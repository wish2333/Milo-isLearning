# ===== AI Learning Compiler 环境变量示例 =====
# 复制为 .env.local 填入真实值；真实 key 绝不要 commit。
# bun 默认不自动加载 .env.local，运行脚本时需显式：
#   bun --env-file=.env.local run scripts/ping.ts
#   bun --env-file=.env.local run scripts/prompt-eval.ts --agent ... --provider sensenova ...

# 应用版本
NEXT_PUBLIC_APP_VERSION=0.1.0-m1

# ===== 默认 LLM 供应商 / 模型（用户可在 Settings 中覆盖）=====
# 取值：deepseek | glm | sensenova
# 默认走 sensenova 通道：商汤大模型平台托管的 deepseek-v4-flash，OpenAI 兼容协议
DEFAULT_LLM_PROVIDER=sensenova

# 默认模型（必须随 DEFAULT_LLM_PROVIDER 走对应供应商）：
#   sensenova：deepseek-v4-flash（推荐，本仓库默认测试通道）/ 其他 SenseNova 托管模型
#   deepseek ：deepseek-v4-flash（快速）/ deepseek-v4-pro（强）
#              旧 ID：deepseek-chat / deepseek-reasoner（2026-07-24 退役，勿用）
#   glm      ：glm-5.2（旗舰）/ glm-5-turbo（快速）
#              旧 ID：glm-4-plus / glm-4-flash / glm-4.7（已过时）
DEFAULT_LLM_MODEL=deepseek-v4-flash

# 遥测后端（MVP 用 console）
# 取值：console | none
TELEMETRY_BACKEND=console

# ===== 供应商 API Key（按需配置至少一项）=====
# SenseNova（默认测试通道）：https://token.sensenova.cn
# 托管 deepseek-v4-flash 等模型，OpenAI 兼容协议
SENSENOVA_API_KEY=

# 原生 DeepSeek：https://api.deepseek.com
DEEPSEEK_API_KEY=

# 智谱 GLM：Coding Plan 端点（默认）或公开端点（覆盖 GLM_BASE_URL）
GLM_API_KEY=

# ===== 可选：覆盖各供应商默认模型 =====
# SENSENOVA_MODEL=deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek-v4-flash
# GLM_MODEL=glm-5.2

# ===== 可选：覆盖各供应商默认 baseURL =====
# SenseNova 默认：https://token.sensenova.cn/v1
# SENSENOVA_BASE_URL=

# 原生 DeepSeek 默认：https://api.deepseek.com（不带 /v1）
# DEEPSEEK_BASE_URL=

# GLM 默认走 Coding Plan 端点（/api/coding/paas/v4）；
# 若切换回公开端点，设为 https://open.bigmodel.cn/api/paas/v4
# GLM_BASE_URL=

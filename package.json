{
  "name": "ai-learning-compiler",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "ping": "bun run scripts/ping.ts",
    "eval": "bun run scripts/prompt-eval.ts",
    "m3-smoke": "bun --env-file=.env.local run scripts/m3-smoke.ts",
    "og:render": "bun run scripts/render-og.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:status": "bun run scripts/db-status.ts",
    "db:reset": "bun run scripts/db-reset.ts",
    "db:backup": "bun run scripts/db-backup.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "nanoid": "^5.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.50.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "ts-fsrs": "5.4.1",
    "zod": "^3.23.8",
    "zod-error": "^1.5.0",
    "zod-to-json-schema": "^3.23.5",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.61.1",
    "@types/bun": "^1.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.19",
    "cn-font-split": "^7.4.3",
    "eslint": "^9",
    "eslint-config-next": "^15",
    "husky": "^9",
    "jsdom": "^25.0.0",
    "lint-staged": "^15",
    "postcss": "^8.4.39",
    "prettier": "^3.3.0",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}

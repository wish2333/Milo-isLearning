# 依赖
node_modules/
bun.lock
bun.lockb

# 构建产物
.next/
out/
build/
dist/

# 生成文件
next-env.d.ts
tsconfig.tsbuildinfo
*.tsbuildinfo

# 第三方 / 参考资料（不属于本仓库源码）
references/

# 报告与录制（运行时生成）
reports/
__recordings__/

# ===== 出 M2.5 范围、保留原有风格 =====

